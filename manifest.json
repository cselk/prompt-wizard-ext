{
  "manifest_version": 3,
  "name": "Cito",
  "version": "1.4.0",
  "description": "Professional prompt manager with custom templates, persona presets, and a floating snippet menu for ChatGPT, Claude, and Gemini.",
  "permissions": ["activeTab", "scripting", "storage"],
  "options_page": "options.html",
  "action": {
    "default_popup": "popup.html",
    "default_icon": "cito_icon.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "48": "cito_icon.png",
    "128": "cito_icon.png"
  }
}
